+/* ---- PATCHED: minimal extra-sprite bridge --------------------------------
+ *
+ * One C function does everything: read tile + palette bytes from ROM,
+ * decode them into RGBA, store with screen position + priority. JS does
+ * ALL game-specific work (ROM offset lookup tables, animation state,
+ * sub-pixel positioning, etc.). The renderer hook (video-software.c)
+ * iterates these per scanline and blits decoded pixels into the line
+ * buffer at the given priority -- no GBA semantics, just pixels with
+ * z-ordering against BG layers.
+ */
+
+#define EXTRA_MAX             8
+#define EXTRA_MAX_W           32
+#define EXTRA_MAX_H           32
+#define EXTRA_PIXEL_BUF_BYTES (EXTRA_MAX_W * EXTRA_MAX_H * 2)  // RGB555 halfwords
+
+struct ExtraSprite {
+	int      active;
+	int16_t  screen_x;
+	int16_t  screen_y;
+	int      width;
+	int      height;
+	int      priority;       // 0..3, lower = on top
+	uint16_t pixels[EXTRA_MAX_W * EXTRA_MAX_H];  // RGB555; alpha-zero color = transparent
+};
+
+struct ExtraSprite extra_sprites[EXTRA_MAX];
+
+/* LZ77 decoder for GBA ROM compressed data. Header is one byte (compression
+ * type, must be 0x10) + 3 bytes little-endian decompressed size. */
+static void lz77_decode(struct mCore* c, uint32_t src, uint8_t* dst, uint32_t out_len) {
+	uint32_t header = c->busRead32(c, src); src += 4;
+	uint32_t total_size = (header >> 8) & 0x00FFFFFF;
+	if (total_size > out_len) total_size = out_len;
+	uint32_t written = 0;
+	while (written < total_size) {
+		uint8_t flags = (uint8_t) c->busRead8(c, src++);
+		for (int b = 0; b < 8 && written < total_size; ++b) {
+			if (flags & 0x80) {
+				uint8_t hi = (uint8_t) c->busRead8(c, src++);
+				uint8_t lo = (uint8_t) c->busRead8(c, src++);
+				int length = (hi >> 4) + 3;
+				int dist   = (((hi & 0xF) << 8) | lo) + 1;
+				for (int i = 0; i < length && written < total_size; ++i) {
+					dst[written] = (written >= (uint32_t) dist) ? dst[written - dist] : 0;
+					written++;
+				}
+			} else {
+				dst[written++] = (uint8_t) c->busRead8(c, src++);
+			}
+			flags <<= 1;
+		}
+	}
+}
+
+/* Decode a w*h block of 4bpp or 8bpp tile bytes into RGB555 pixels.
+ * Tile layout: 8x8 tile = 32 bytes (4bpp) or 64 bytes (8bpp). Tiles are
+ * stored linearly in row-major order. */
+static void decode_tiles(const uint8_t* tiles, int w, int h, const uint16_t* palette, int is_8bpp,
+                         int hflip, int vflip, uint16_t* out) {
+	int tw = w / 8;
+	for (int py = 0; py < h; ++py) {
+		int sy = vflip ? (h - 1 - py) : py;
+		for (int px = 0; px < w; ++px) {
+			int sx = hflip ? (w - 1 - px) : px;
+			int tile_x = sx / 8, in_x = sx % 8;
+			int tile_y = sy / 8, in_y = sy % 8;
+			int tile_idx = tile_y * tw + tile_x;
+			int color_idx;
+			if (is_8bpp) {
+				int off = tile_idx * 64 + in_y * 8 + in_x;
+				color_idx = tiles[off];
+			} else {
+				int off = tile_idx * 32 + in_y * 4 + (in_x / 2);
+				uint8_t bb = tiles[off];
+				color_idx = (in_x & 1) ? (bb >> 4) : (bb & 0xF);
+			}
+			uint16_t c;
+			if (color_idx == 0) c = 0x8000;  // sentinel: transparent (alpha bit set)
+			else c = palette[color_idx] & 0x7FFF;
+			out[py * w + px] = c;
+		}
+	}
+}
+
+/* Extended signature: (tile_rom_addr, tile_blob_offset, tile_blob_total)
+ * lets the caller point at a sub-range of a larger blob (e.g., one frame
+ * of a 9-frame compressed sprite sheet). For uncompressed: reads
+ * width*height/2 bytes starting at tile_rom_addr + tile_blob_offset.
+ * For compressed: decompresses tile_blob_total bytes from tile_rom_addr,
+ * then takes the slice starting at tile_blob_offset.
+ *
+ * Same for palette: (palette_rom_addr, palette_blob_offset, palette_blob_total),
+ * compressed flag shared with tile (palettes from pokefirered are usually
+ * uncompressed; if so pass palette_blob_total = palette_colors*2 and
+ * palette_blob_offset = 0). */
+EMSCRIPTEN_KEEPALIVE void wasm_set_extra_sprite(
+		int slot,
+		int16_t screen_x, int16_t screen_y,
+		int width, int height,
+		uint32_t tile_rom_addr,
+		uint32_t tile_blob_offset,
+		uint32_t tile_blob_total,
+		int compressed,
+		int is_8bpp,
+		uint32_t palette_rom_addr,
+		uint32_t palette_blob_offset,
+		uint32_t palette_blob_total,
+		int palette_compressed,
+		int palette_colors,
+		int hflip, int vflip,
+		int priority) {
+	if (slot < 0 || slot >= EXTRA_MAX) return;
+	if (width <= 0 || width > EXTRA_MAX_W || height <= 0 || height > EXTRA_MAX_H) return;
+	if (palette_colors < 0 || palette_colors > 256) return;
+	struct mCore* c = wasm_get_core();
+	if (!c) return;
+
+	uint32_t tile_size = (uint32_t)(width * height) / (is_8bpp ? 1 : 2);
+
+	// Decompress / copy tile bytes.
+	static uint8_t blob_buf[16384];
+	uint8_t tile_buf[2048];
+	if (tile_size > sizeof(tile_buf)) tile_size = sizeof(tile_buf);
+	if (compressed) {
+		uint32_t n = tile_blob_total > sizeof(blob_buf) ? sizeof(blob_buf) : tile_blob_total;
+		lz77_decode(c, tile_rom_addr, blob_buf, n);
+		uint32_t off = tile_blob_offset;
+		for (uint32_t i = 0; i < tile_size; ++i) {
+			tile_buf[i] = (off + i < n) ? blob_buf[off + i] : 0;
+		}
+	} else {
+		for (uint32_t i = 0; i < tile_size; ++i) {
+			tile_buf[i] = (uint8_t) c->busRead8(c, tile_rom_addr + tile_blob_offset + i);
+		}
+	}
+
+	// Read palette. Palette is RGB555 halfwords, so palette_colors*2 bytes.
+	uint16_t pal[256] = {0};
+	uint32_t pal_bytes = (uint32_t)palette_colors * 2;
+	if (palette_compressed) {
+		uint32_t n = palette_blob_total > sizeof(blob_buf) ? sizeof(blob_buf) : palette_blob_total;
+		lz77_decode(c, palette_rom_addr, blob_buf, n);
+		for (int i = 0; i < palette_colors; ++i) {
+			uint32_t off = palette_blob_offset + i * 2;
+			uint16_t lo = (off     < n) ? blob_buf[off]     : 0;
+			uint16_t hi = (off + 1 < n) ? blob_buf[off + 1] : 0;
+			pal[i] = lo | (hi << 8);
+		}
+	} else {
+		for (int i = 0; i < palette_colors && i < 256; ++i) {
+			pal[i] = (uint16_t) c->busRead16(c, palette_rom_addr + palette_blob_offset + i * 2);
+		}
+		(void)pal_bytes;
+	}
+
+	struct ExtraSprite* s = &extra_sprites[slot];
+	s->screen_x = screen_x;
+	s->screen_y = screen_y;
+	s->width    = width;
+	s->height   = height;
+	s->priority = priority & 3;
+	decode_tiles(tile_buf, width, height, pal, is_8bpp, hflip, vflip, s->pixels);
+	s->active   = 1;
+}
+
+EMSCRIPTEN_KEEPALIVE void wasm_clear_extra_sprite(int slot) {
+	if (slot < 0 || slot >= EXTRA_MAX) return;
+	extra_sprites[slot].active = 0;
+}
+
+EMSCRIPTEN_KEEPALIVE void wasm_clear_extra_sprites(void) {
+	for (int i = 0; i < EXTRA_MAX; ++i) extra_sprites[i].active = 0;
+}
+
+/* ----------------------------------------------------------------------------
+ * Engine-native peer OBJ injection (mirrors snes9x's gfx.cpp pattern).
+ *
+ * Parallel OAM + OBJ-VRAM + OBJ-palette tables. The renderer's second OBJ
+ * pass (video-software.c::wasm_render_extras_native) swaps these into the
+ * engine state for the duration of the pass, runs PreprocessSprite on each
+ * active entry, then restores. JS writes ROM-resident tile bytes / palette
+ * half-words / OAM attrs directly into the fixed tables via HEAPU8 views
+ * obtained from the *_ptr accessors. No flag — the pass always runs, empty
+ * state renders nothing. */
+
+#define EXTRAS_MAX_OBJ          128
+#define EXTRAS_OBJ_VRAM_BYTES   0x8000           /* 32 KB OBJ VRAM mirror */
+#define EXTRAS_OBJ_PAL_ENTRIES  256              /* 16 OBJ palettes × 16 colors */
+
+static struct GBAObj g_extras_oam[EXTRAS_MAX_OBJ];
+static int           g_extras_obj_active[EXTRAS_MAX_OBJ];
+static uint8_t       g_extras_obj_vram[EXTRAS_OBJ_VRAM_BYTES];
+static uint16_t      g_extras_obj_palette_bgr555[EXTRAS_OBJ_PAL_ENTRIES];
+
+/* Internal C-linkage accessors used by software-obj.c via extern. */
+struct GBAObj* wasm_extras_oam(void)               { return g_extras_oam; }
+int*           wasm_extras_obj_active(void)        { return g_extras_obj_active; }
+uint8_t*       wasm_extras_obj_vram(void)          { return g_extras_obj_vram; }
