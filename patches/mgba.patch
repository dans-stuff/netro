+/* PATCHED: extra-sprite renderer hook. See src/platform/wasm/memory.c.
+ * JS sets pre-decoded RGB555 pixels + screen position; we blit per scanline
+ * with priority for BG composite. No GBA semantics. */
+#define EXTRA_MAX             8
+#define EXTRA_MAX_W           32
+#define EXTRA_MAX_H           32
+struct ExtraSprite {
+	int      active;
+	int16_t  screen_x;
+	int16_t  screen_y;
+	int      width;
+	int      height;
+	int      priority;
+	uint16_t pixels[EXTRA_MAX_W * EXTRA_MAX_H];
+};
+extern struct ExtraSprite extra_sprites[EXTRA_MAX];
+
+/* Returns a bitmap of priority levels we wrote to (so the compositor knows
+ * to use the OBJ buffer for those priorities on this scanline). Without
+ * this, our pixels only show up on scanlines where the game's own sprites
+ * are also being drawn -- compositor skips OBJ otherwise. */
+static int wasm_blit_extras_scanline(struct GBAVideoSoftwareRenderer* renderer, int y) {
+	int spriteLayers = 0;
+	for (int i = 0; i < EXTRA_MAX; ++i) {
+		const struct ExtraSprite* s = &extra_sprites[i];
+		if (!s->active) continue;
+		int dy = y - s->screen_y;
+		if (dy < 0 || dy >= s->height) continue;
+		uint32_t flags = (uint32_t) s->priority << OFFSET_PRIORITY;
+		const uint16_t* row = &s->pixels[dy * s->width];
+		int wrote = 0;
+		for (int dx = 0; dx < s->width; ++dx) {
+			int x = s->screen_x + dx;
+			if (x < 0 || x >= GBA_VIDEO_HORIZONTAL_PIXELS) continue;
+			uint16_t c = row[dx];
+			if (c & 0x8000) continue;  // transparent sentinel
+			uint32_t cur = renderer->spriteLayer[x];
+			if ((cur & FLAG_ORDER_MASK) > flags) {
+				/* Convert RGB555 -> mColor (the format the compositor
+				 * expects). Without this, R5 lands in mColor's RED byte
+				 * and we get the "blood red" cast on everything. */
+				uint32_t mc = mColorFrom555(c & 0x7FFF);
+				renderer->spriteLayer[x] = mc | flags;
+				wrote = 1;
 			}
 		}
+		if (wrote) spriteLayers |= 1 << s->priority;
 	}
+	return spriteLayers;
 }
 
