+/* ---- BG scroll shadow ----------------------------------------------------
+ * mGBA's IO read returns junk for write-only BG*OFS regs. We need the
+ * last-written value so JS can derive sub-pixel camera offset for ghost
+ * positioning during walks. Hooked from GBAIOWrite in io.c. */
+static uint16_t bg_hofs[4];
+static uint16_t bg_vofs[4];
+void wasm_record_bg_hofs(int bg, uint16_t value) { if ((unsigned)bg < 4) bg_hofs[bg] = value; }
+void wasm_record_bg_vofs(int bg, uint16_t value) { if ((unsigned)bg < 4) bg_vofs[bg] = value; }
+EMSCRIPTEN_KEEPALIVE uint32_t wasm_get_bg_hofs(int bg) { return ((unsigned)bg < 4) ? bg_hofs[bg] : 0; }
+EMSCRIPTEN_KEEPALIVE uint32_t wasm_get_bg_vofs(int bg) { return ((unsigned)bg < 4) ? bg_vofs[bg] : 0; }
