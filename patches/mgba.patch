+/* ---- PATCHED: emulated-bus memory access for the multiplayer overlay -------
+ *
+ * Exposes the active mCore's busRead/busWrite as EMSCRIPTEN_KEEPALIVE'd
+ * functions so JS can `cwrap` them and read/write the emulated GBA's EWRAM /
+ * IWRAM / OAM at arbitrary addresses every frame. Used by the multiplayer
+ * ghost-rendering adapters (firered.ts, emerald.ts) to extract player coords
+ * and inject peer OAM entries into the engine's shadow OAM buffer.
+ *
+ * Safe to call between frames -- which is what we do (from the JS
+ * videoFrameStartedCallback). Callers must NOT call these while the emu
+ * thread is mid-frame.
+ *
+ * The `renderer` symbol is defined in main.c. We declare an opaque shim
+ * (`wasm_get_core`) implemented there to avoid pulling main.h into here.
+ */
+
+struct mCore* wasm_get_core(void);
+
+EMSCRIPTEN_KEEPALIVE uint8_t wasm_read_u8(uint32_t addr) {
+	struct mCore* c = wasm_get_core();
+	if (!c) return 0;
+	return (uint8_t)c->busRead8(c, addr);
+}
+EMSCRIPTEN_KEEPALIVE uint16_t wasm_read_u16(uint32_t addr) {
+	struct mCore* c = wasm_get_core();
+	if (!c) return 0;
+	return (uint16_t)c->busRead16(c, addr);
+}
+EMSCRIPTEN_KEEPALIVE uint32_t wasm_read_u32(uint32_t addr) {
+	struct mCore* c = wasm_get_core();
+	if (!c) return 0;
+	return c->busRead32(c, addr);
+}
+EMSCRIPTEN_KEEPALIVE void wasm_write_u8(uint32_t addr, uint8_t value) {
+	struct mCore* c = wasm_get_core();
+	if (c) c->busWrite8(c, addr, value);
+}
+EMSCRIPTEN_KEEPALIVE void wasm_write_u16(uint32_t addr, uint16_t value) {
+	struct mCore* c = wasm_get_core();
+	if (c) c->busWrite16(c, addr, value);
+}
+EMSCRIPTEN_KEEPALIVE void wasm_write_u32(uint32_t addr, uint32_t value) {
+	struct mCore* c = wasm_get_core();
+	if (c) c->busWrite32(c, addr, value);
+}
+
+/* Bulk read into a heap buffer allocated by JS (Module._malloc). Cheaper than
+ * a loop of wasm_read_u8 when the adapter wants OAM (1KB) or a chunk of EWRAM.
+ * Caller passes the destination pointer (from Module._malloc) and length;
+ * we copy bytes byte-at-a-time through busRead8 (handles all memory regions
+ * including OAM/VRAM correctly). */
+EMSCRIPTEN_KEEPALIVE void wasm_read_bytes(uint32_t addr, uint8_t* dst, uint32_t len) {
+	struct mCore* c = wasm_get_core();
+	if (!c || !dst) return;
+	for (uint32_t i = 0; i < len; ++i) {
+		dst[i] = (uint8_t)c->busRead8(c, addr + i);
+	}
+}
+
+/* ---- PATCHED: runtime provenance tracking --------------------------------
+ *
+ * Tracks where bytes in IWRAM / EWRAM / OBJ VRAM / OBJ palette RAM came
+ * from in ROM. Hooks the BIOS handlers for LZ77UnComp (SWI 0x11/0x12),
+ * CpuSet (SWI 0x0B), CpuFastSet (SWI 0x0C). Granularity is 32 bytes (one
+ * 4bpp tile or one 16-color palette bank).
+ *
+ * Chained provenance: pokefirered loads sprites via LZ77 (ROM -> IWRAM
+ * workbuffer) then CpuSet (IWRAM -> VRAM). The LZ77 hook records IWRAM
+ * provenance; the CpuSet hook copies that provenance into the VRAM
+ * provenance table when its src is IWRAM/EWRAM.
+ *
+ * JS queries via wasm_get_obj_tile_provenance / wasm_get_obj_palette_provenance
+ * to find the ROM source for a peer's currently-displayed sprite, then
+ * broadcasts those offsets over the wire (no pixel bytes), and peers feed
+ * them back into wasm_set_extra_sprite.
+ */
+
+/* Fine-grained slot tracking: 4 bytes per slot.
+ *
+ * Rationale: all standard GBA copy operations (CpuCopy16, CpuFastSet, DMA)
+ * are at LEAST 4-byte aligned. Using 4-byte slots means every operation
+ * covers an integer number of slots exactly -- no "partial slot" garbage
+ * from buffers like gPlttBufferFaded that are 4-aligned but not 32-aligned.
+ *
+ * The public query API (wasm_query_obj_tile_prov / wasm_query_obj_palette_prov)
+ * aggregates 8 consecutive 4-byte slots into one 32-byte block provenance.
+ * If the 8 slots are mutually consistent (same rom_addr/blob_total/compressed
+ * and contiguous blob_offsets at 4-byte stride), we return a single coherent
+ * (rom_addr, blob_offset, blob_total, compressed). Otherwise we return zero
+ * (the block had MIXED sources and we can't reproduce it cleanly).
+ */
+
+#define PROV_SLOT_BYTES 4
+
+struct ProvSlot {
+	uint32_t rom_addr;     /* 0 if unknown */
+	uint32_t blob_offset;  /* byte offset into the post-decompression blob */
+	uint32_t blob_total;   /* total decompressed size of the blob */
+	uint8_t  compressed;
+	uint8_t  _pad[3];
+};
+
+#define PROV_EWRAM_SLOTS    (256 * 1024 / PROV_SLOT_BYTES)
+#define PROV_IWRAM_SLOTS    ( 32 * 1024 / PROV_SLOT_BYTES)
+#define PROV_OBJVRAM_SLOTS  ( 32 * 1024 / PROV_SLOT_BYTES)  /* 0x06010000..0x06017FFF */
+#define PROV_OBJPAL_SLOTS   ( 512        / PROV_SLOT_BYTES) /* 0x05000200..0x050003FF */
+
+static struct ProvSlot prov_ewram   [PROV_EWRAM_SLOTS];
+static struct ProvSlot prov_iwram   [PROV_IWRAM_SLOTS];
+static struct ProvSlot prov_objvram [PROV_OBJVRAM_SLOTS];
+static struct ProvSlot prov_objpal  [PROV_OBJPAL_SLOTS];
+
+static struct ProvSlot* prov_slot_for(uint32_t addr) {
+	uint32_t region = addr >> 24;
+	switch (region) {
+	case 0x02: {  /* EWRAM */
+		uint32_t off = (addr - 0x02000000) & 0x3FFFF;
+		return &prov_ewram[off / PROV_SLOT_BYTES];
+	}
+	case 0x03: {  /* IWRAM */
+		uint32_t off = (addr - 0x03000000) & 0x7FFF;
+		return &prov_iwram[off / PROV_SLOT_BYTES];
+	}
+	case 0x05: {  /* PALETTE: only OBJ half */
+		if (addr < 0x05000200 || addr > 0x050003FF) return 0;
+		uint32_t off = addr - 0x05000200;
+		return &prov_objpal[off / PROV_SLOT_BYTES];
+	}
+	case 0x06: {  /* VRAM: only OBJ region */
+		if (addr < 0x06010000 || addr > 0x06017FFF) return 0;
+		uint32_t off = addr - 0x06010000;
+		return &prov_objvram[off / PROV_SLOT_BYTES];
+	}
+	}
+	return 0;
+}
+
+/* Fill provenance for [dst .. dst+len). With PROV_SLOT_BYTES=4, all
+ * standard GBA copies (4-byte aligned) cover slots cleanly with no
+ * partial-slot ambiguity. dst MUST be 4-byte aligned (we down-align if
+ * not, but the caller should ensure it). */
+static void record_prov_range(uint32_t dst, uint32_t len, uint32_t rom_addr,
+                              uint32_t blob_total, uint32_t src_blob_offset,
+                              uint8_t compressed) {
+	uint32_t aligned_dst = dst & ~3u;
+	uint32_t end = dst + len;
+	for (uint32_t a = aligned_dst; a < end; a += PROV_SLOT_BYTES) {
+		struct ProvSlot* p = prov_slot_for(a);
+		if (!p) continue;
+		p->rom_addr    = rom_addr;
+		p->blob_total  = blob_total;
+		p->blob_offset = src_blob_offset + (a - aligned_dst);
+		p->compressed  = compressed;
+	}
+}
+
+/* Called from bios.c on LZ77UnCompWram/Vram (SWI 0x11/0x12). */
+void wasm_prov_record_lz77(uint32_t src_rom, uint32_t dst, uint32_t decompressed_size) {
+	if ((src_rom >> 24) < 0x08) return;  /* not from ROM, ignore */
+	record_prov_range(dst, decompressed_size, src_rom, decompressed_size, 0, 1);
+}
+
+/* Called from bios.c on CpuSet/CpuFastSet (SWI 0x0B/0x0C) -- copy mode. */
+void wasm_prov_record_cpuset(uint32_t src, uint32_t dst, uint32_t bytes) {
+	/* If src is in ROM, record directly as uncompressed. */
+	if ((src >> 24) >= 0x08 && (src >> 24) <= 0x0D) {
+		record_prov_range(dst, bytes, src, bytes, 0, 0);
+		return;
+	}
+	/* Otherwise chain through IWRAM/EWRAM provenance, slot by slot. */
+	uint32_t src_aligned = src & ~3u;
+	uint32_t dst_aligned = dst & ~3u;
+	uint32_t end = dst + bytes;
+	for (uint32_t off = 0; dst_aligned + off < end; off += PROV_SLOT_BYTES) {
+		struct ProvSlot* sp = prov_slot_for(src_aligned + off);
+		struct ProvSlot* dp = prov_slot_for(dst_aligned + off);
+		if (!dp) continue;
+		if (sp && sp->rom_addr) {
+			dp->rom_addr    = sp->rom_addr;
+			dp->blob_total  = sp->blob_total;
+			dp->blob_offset = sp->blob_offset;
+			dp->compressed  = sp->compressed;
+		}
+		/* If sp is empty, leave dp alone (sticky provenance). Clearing
+		 * dp here was a bug -- pokefirered's per-frame palette fade/blend
+		 * does small CpuCopy16's from untracked scratch buffers, which
+		 * would otherwise wipe out the good provenance LoadPalette set
+		 * at map enter. Stale prov pointing at slightly-old ROM bytes is
+		 * vastly preferable to empty prov. */
+	}
+}
+
+/* Aggregate `n` consecutive 4-byte slots starting at `slots[0]` into a
+ * single coherent provenance record. Returns 1 if the slots are mutually
+ * consistent (same rom_addr/blob_total/compressed, contiguous blob_offsets
+ * at 4-byte stride), 0 otherwise. On success, fills *out with the prov
+ * for the START of the aggregated block. */
+static int aggregate_slots(const struct ProvSlot* slots, int n, struct ProvSlot* out) {
+	if (n <= 0) return 0;
+	uint32_t rom = slots[0].rom_addr;
+	uint32_t total = slots[0].blob_total;
+	uint32_t base_offset = slots[0].blob_offset;
+	uint8_t comp = slots[0].compressed;
+	if (!rom) return 0;
+	for (int i = 1; i < n; ++i) {
+		if (slots[i].rom_addr != rom) return 0;
+		if (slots[i].blob_total != total) return 0;
+		if (slots[i].compressed != comp) return 0;
+		if (slots[i].blob_offset != base_offset + (uint32_t)i * PROV_SLOT_BYTES) return 0;
+	}
+	out->rom_addr    = rom;
+	out->blob_offset = base_offset;
+	out->blob_total  = total;
+	out->compressed  = comp;
+	return 1;
+}
+
+static struct ProvSlot prov_last_query;
+
+EMSCRIPTEN_KEEPALIVE void wasm_query_obj_tile_prov(int tile_id) {
+	prov_last_query = (struct ProvSlot){0};
+	/* Each tile is 32 bytes = 8 consecutive 4-byte slots in prov_objvram. */
+	int base = tile_id * 8;
+	if (tile_id < 0 || base + 8 > PROV_OBJVRAM_SLOTS) return;
+	aggregate_slots(&prov_objvram[base], 8, &prov_last_query);
+}
+EMSCRIPTEN_KEEPALIVE void wasm_query_obj_palette_prov(int bank) {
+	prov_last_query = (struct ProvSlot){0};
+	/* Each palette bank is 32 bytes = 8 consecutive 4-byte slots. */
+	int base = bank * 8;
+	if (bank < 0 || base + 8 > PROV_OBJPAL_SLOTS) return;
+	aggregate_slots(&prov_objpal[base], 8, &prov_last_query);
+}
+EMSCRIPTEN_KEEPALIVE uint32_t wasm_prov_rom_addr   (void) { return prov_last_query.rom_addr; }
+EMSCRIPTEN_KEEPALIVE uint32_t wasm_prov_blob_offset(void) { return prov_last_query.blob_offset; }
+EMSCRIPTEN_KEEPALIVE uint32_t wasm_prov_blob_total (void) { return prov_last_query.blob_total; }
+EMSCRIPTEN_KEEPALIVE uint32_t wasm_prov_compressed (void) { return prov_last_query.compressed; }
