+/* ----------------------------------------------------------------------------
+ * PATCHED: engine-native peer OBJ rendering. See src/platform/wasm/memory.c
+ * for the parallel state. Called from PreprocessSpriteLayer as a second
+ * OBJ pass; swaps engine VRAM+palette with our shadow copies, renders each
+ * active extras OAM entry via the engine's own PreprocessSprite, restores.
+ * Static file-scope swap buffers (32 KB + 1 KB) — would blow the 64 KB
+ * wasm stack if allocated per-call. */
+
+extern struct GBAObj* wasm_extras_oam(void);
+extern int*           wasm_extras_obj_active(void);
+extern uint8_t*       wasm_extras_obj_vram(void);
+extern uint16_t*      wasm_extras_obj_palette_bgr555(void);
+extern int            wasm_extras_max_obj(void);
+
+static uint8_t s_saved_obj_vram[0x8000];
+static mColor  s_saved_obj_palette[256];
+
+int wasm_render_extras_native(struct GBAVideoSoftwareRenderer* renderer, int y) {
+	const int max_obj = wasm_extras_max_obj();
+	int*           active   = wasm_extras_obj_active();
+	struct GBAObj* obj_arr  = wasm_extras_oam();
+
+	int any = 0;
+	for (int i = 0; i < max_obj; ++i) {
+		if (active[i]) { any = 1; break; }
+	}
+	if (!any) return 0;
+
+	uint8_t* engine_vram = ((uint8_t*) renderer->d.vram) + BASE_TILE;
+	memcpy(s_saved_obj_vram, engine_vram, 0x8000);
+	memcpy(engine_vram, wasm_extras_obj_vram(), 0x8000);
+
+	memcpy(s_saved_obj_palette, &renderer->normalPalette[0x100], sizeof(mColor) * 256);
+	const uint16_t* peer_pal = wasm_extras_obj_palette_bgr555();
+	for (int i = 0; i < 256; ++i) {
+		renderer->normalPalette[0x100 + i] = mColorFrom555(peer_pal[i] & 0x7FFF);
+	}
+
+	int spriteLayers = 0;
+	int saved_start = renderer->start;
+	int saved_end   = renderer->end;
+	for (int i = 0; i < max_obj; ++i) {
+		if (!active[i]) continue;
+		struct GBAObj* sprite = &obj_arr[i];
+		if (GBAObjAttributesAIsTransformed(sprite->a)) continue;
+		int objY    = GBAObjAttributesAGetY(sprite->a) + renderer->objOffsetY;
+		int shape   = GBAObjAttributesAGetShape(sprite->a);
+		int size    = GBAObjAttributesBGetSize(sprite->b);
+		int h       = GBAVideoObjSizes[shape * 4 + size][1];
+		int endY    = objY + h;
+		if (y < objY && (endY < 256 || y >= endY - 256)) continue;
+		if (y >= endY) continue;
+
+		for (int w = 0; w < renderer->nWindows; ++w) {
+			renderer->currentWindow = renderer->windows[w].control;
+			renderer->start = w ? renderer->windows[w - 1].endX : 0;
+			renderer->end   = renderer->windows[w].endX;
+			if (!GBAWindowControlIsObjEnable(renderer->currentWindow.packed)
+			    && !GBARegisterDISPCNTIsObjwinEnable(renderer->dispcnt)) {
+				continue;
+			}
+			int drawn = GBAVideoSoftwareRendererPreprocessSprite(renderer, sprite, i, y);
+			spriteLayers |= drawn << GBAObjAttributesCGetPriority(sprite->c);
+		}
+	}
+	renderer->start = saved_start;
+	renderer->end   = saved_end;
+
+	memcpy(engine_vram, s_saved_obj_vram, 0x8000);
+	memcpy(&renderer->normalPalette[0x100], s_saved_obj_palette, sizeof(mColor) * 256);
+	return spriteLayers;
 }
