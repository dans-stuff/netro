diff --git a/higan/sfc/ppu-performance/object.cpp b/higan/sfc/ppu-performance/object.cpp
index 8dfa2b1..0fb4ec8 100644
--- a/higan/sfc/ppu-performance/object.cpp
+++ b/higan/sfc/ppu-performance/object.cpp
@@ -124,6 +124,74 @@ auto PPU::Object::render() -> void {
     if(io.aboveEnable && !windowAbove[x]) ppu.dac.plotAbove(x, source, priority[x], ppu.dac.cgram[palette[x]]);
     if(io.belowEnable && !windowBelow[x]) ppu.dac.plotBelow(x, source, priority[x], ppu.dac.cgram[palette[x]]);
   }
+
+  // mplay extras pass — ghost sprites from peer adapters.
+  // Shadow tables written by TypeScript worker; cleared each frame before render.
+  mplayRenderExtras(windowAbove, windowBelow);
+}
+
+// mplay extras-pass forward declarations. Break out of higan::SuperFamicom
+// so the externs resolve against the file-scope globals in mplay_extras.cpp.
+}  // end namespace higan::SuperFamicom
+struct MplayExtraObj { int16_t x, y; uint16_t tile; uint8_t palette, priority, hflip, vflip, width, height; };
+extern uint8_t       mplay_extras_vram[];
+extern uint8_t       mplay_extras_cgram[];
+extern MplayExtraObj mplay_extras_obj[];
+extern "C" uint32_t  mplay_extras_obj_count();
+namespace higan::SuperFamicom {  // reopen
+
+auto PPU::Object::mplayRenderExtras(bool* windowAbove, bool* windowBelow) -> void {
+
+  const uint32_t count = mplay_extras_obj_count();
+  const uint  scanline = ppu.vcounter();
+
+  for(uint32_t i = 0; i < count; i++) {
+    const auto& obj = mplay_extras_obj[i];
+    if(!obj.tile && !obj.palette) continue;  // empty slot
+
+    const uint w = obj.width  ? obj.width  : 8;
+    const uint h = obj.height ? obj.height : 8;
+    const uint tileW = w >> 3;
+    const uint tileH = h >> 3;
+
+    for(uint ty = 0; ty < tileH; ty++) {
+      int sy = obj.y + (obj.vflip ? (tileH - 1 - ty) : ty) * 8;
+      if(sy < 0 || (uint)sy > scanline || (uint)sy + 7 < scanline) continue;
+      uint row = scanline - sy;
+      if(obj.vflip) row = 7 - row;
+
+      for(uint tx = 0; tx < tileW; tx++) {
+        int sx = (int16_t)obj.x + (obj.hflip ? (tileW - 1 - tx) : tx) * 8;
+        uint tileIdx = obj.tile + ty * tileW + tx;
+        const uint8_t* tileData = mplay_extras_vram + tileIdx * 32;
+        uint rowOff = row * 2;
+        uint8_t lo = tileData[rowOff];
+        uint8_t hi = tileData[rowOff + 1];
+        uint8_t lo2 = tileData[rowOff + 16];
+        uint8_t hi2 = tileData[rowOff + 17];
+
+        for(uint px = 0; px < 8; px++) {
+          int screenX = sx + (obj.hflip ? 7 - px : px);
+          if(screenX < 0 || screenX >= 256) continue;
+          uint shift = 7 - px;
+          uint color = ((lo  >> shift) & 1)
+                     | (((hi  >> shift) & 1) << 1)
+                     | (((lo2 >> shift) & 1) << 2)
+                     | (((hi2 >> shift) & 1) << 3);
+          if(!color) continue;
+          uint8_t cgramIdx = (obj.palette << 4) + color;
+          uint16_t bgr555 = (uint16_t)mplay_extras_cgram[cgramIdx * 2]
+                          | ((uint16_t)mplay_extras_cgram[cgramIdx * 2 + 1] << 8);
+          uint8_t priVal = io.priority[obj.priority & 3];
+          // Match the regular OBJ pass: source is OBJ1 if (128+cgramIdx) < 192,
+          // i.e. cgramIdx < 64 (palettes 0-3). Palettes 4-7 → OBJ2.
+          uint8_t src = (128 + cgramIdx) < 192 ? PPU::Source::OBJ1 : PPU::Source::OBJ2;
+          if(io.aboveEnable && !windowAbove[screenX]) ppu.dac.plotAbove(screenX, src, priVal, bgr555);
+          if(io.belowEnable && !windowBelow[screenX]) ppu.dac.plotBelow(screenX, src, priVal, bgr555);
+        }
+      }
+    }
+  }
 }
 
