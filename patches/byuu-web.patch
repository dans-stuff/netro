+// mplay extras: byuu-side primitives exposed to JS so all game-specific code
+// can live in TypeScript (worker) rather than C++.
+//
+// Two friend structs (mplay_ppu_access, mplay_cart_access) are declared in
+// byuu's ppu.hpp / cartridge.hpp so we can reach the private regions without
+// adding accessor methods to every class. That's the ONLY edit those headers
+// receive — everything else lives here.
+
+#include <emscripten.h>
+#include <stdint.h>
+#include <string.h>
+#include <stdio.h>
+
+#include "../sfc/sfc.hpp"
+
+// Friend trampolines MUST live in higan::SuperFamicom namespace to match the
+// friend declarations in ppu.hpp / cartridge.hpp. C++ friend lookup happens
+// in the namespace of the befriending class.
+namespace higan { namespace SuperFamicom {
+  struct mplay_ppu_access {
+    static void* vram_data() { return ppu.vram.data; }
+    static void* cgram_data() { return ppu.dac.cgram; }
+    static void* oam_data() { return ppu.obj.oam.objects; }
+    static uint32_t oam_size() { return sizeof(ppu.obj.oam.objects); }
+  };
+  struct mplay_cart_access {
+    static void* rom_data() { return cartridge.rom.data(); }
+    static uint32_t rom_size() { return cartridge.rom.size(); }
+  };
+}}
+
+using higan::SuperFamicom::mplay_ppu_access;
+using higan::SuperFamicom::mplay_cart_access;
+using higan::SuperFamicom::cpu;
+
+// ---- region pointer exports ------------------------------------------------
+
+extern "C" {
+
+EMSCRIPTEN_KEEPALIVE uint8_t* mplay_getRomPtr() {
+  return (uint8_t*)mplay_cart_access::rom_data();
+}
+EMSCRIPTEN_KEEPALIVE uint32_t mplay_getRomSize() {
+  return mplay_cart_access::rom_size();
+}
+
+EMSCRIPTEN_KEEPALIVE uint8_t* mplay_getRamPtr() {
+  return (uint8_t*)&cpu.wram[0];  // public; uint8 = Natural<8>, address as bytes
+}
+EMSCRIPTEN_KEEPALIVE uint32_t mplay_getRamSize() {
+  return sizeof(cpu.wram);
+}
+
+EMSCRIPTEN_KEEPALIVE uint8_t* mplay_getVramPtr() {
+  return (uint8_t*)mplay_ppu_access::vram_data();
+}
+EMSCRIPTEN_KEEPALIVE uint32_t mplay_getVramSize() {
+  return 65536;  // 64KB
+}
+
+EMSCRIPTEN_KEEPALIVE uint8_t* mplay_getCgramPtr() {
+  return (uint8_t*)mplay_ppu_access::cgram_data();
+}
+EMSCRIPTEN_KEEPALIVE uint32_t mplay_getCgramSize() {
+  return 512;
+}
+
+EMSCRIPTEN_KEEPALIVE uint8_t* mplay_getOamPtr() {
+  return (uint8_t*)mplay_ppu_access::oam_data();
+}
+EMSCRIPTEN_KEEPALIVE uint32_t mplay_getOamSize() {
+  return mplay_ppu_access::oam_size();
+}
+
+// ---- callSubroutine --------------------------------------------------------
+// Runs a 65816 subroutine to completion without saving/restoring CPU state.
+// Safe to call at any point (frame 0, mid-atlas, etc.) because:
+//   1. Stack is forced to a known safe address ($01F0) so the exit condition
+//      is always well-defined regardless of prior emulator state.
+//   2. CPU is switched to native mode (E=0) with 8-bit accumulator/index
+//      (M=X=1), which matches the expected call convention for all game
+//      decoders we invoke.
+// State corruption is intentional: the caller power-cycles after atlas
+// building, so nothing here needs to survive.
+
+EMSCRIPTEN_KEEPALIVE void mplay_callSubroutine(uint32_t targetAddr) {
+  // Force CPU to a known, safe state before every call.
+  cpu.r.e   = 0;     // native mode (not emulation)
+  cpu.r.p.m = 1;     // 8-bit accumulator
+  cpu.r.p.x = 1;     // 8-bit index registers
+  cpu.r.s.w = 0x01F0; // stack in WRAM page 1, well away from zero-page / vectors
+
+  const uint16_t initial_S = cpu.r.s.w;  // = 0x01F0
+
+  auto pushByte = [&](uint8_t v) {
+    cpu.write(cpu.r.s.w, v);
+    cpu.r.s.w = cpu.r.s.w - 1;
+  };
+  // Push 3 bytes to handle both call conventions:
+  //   RTS (JSR caller): pops PCL+PCH (2)       → S ends at initial_S - 1
+  //   RTL (JSL caller): pops PCL+PCH+bank (3)  → S ends at initial_S
+  // We exit when S >= initial_S - 1 (true for both).
+  // Return target: bank $00, addr $FFFE (unreachable safe address).
+  pushByte(0x00);  // return bank (consumed by RTL; left on stack by RTS)
+  pushByte(0xFF);  // PCH of return addr - 1
+  pushByte(0xFD);  // PCL of return addr - 1
+
+  cpu.r.pc.d = targetAddr & 0xffffff;
+
+  while (cpu.r.s.w < (uint16_t)(initial_S - 1)) {
+    cpu.instruction();
+  }
+}
+
+// ---- powerCycle ------------------------------------------------------------
+
+EMSCRIPTEN_KEEPALIVE void mplay_powerCycle() {
+  higan::SuperFamicom::system.power(false);
+}
+
+}  // extern "C"
+
+// ---- extras-pass shadow tables --------------------------------------------
+
+#include "mplay_extras.hpp"
+#define MPLAY_EXTRA_OBJ_COUNT 128
+MplayExtraObj mplay_extras_obj[MPLAY_EXTRA_OBJ_COUNT];
+uint8_t mplay_extras_vram[32768];
+uint8_t mplay_extras_cgram[256];  // 128 words; covers one full OBJ palette row (8×16 colours)
+
+extern "C" {
+
+EMSCRIPTEN_KEEPALIVE void* mplay_extras_obj_ptr() { return mplay_extras_obj; }
+EMSCRIPTEN_KEEPALIVE uint32_t mplay_extras_obj_count() { return MPLAY_EXTRA_OBJ_COUNT; }
+EMSCRIPTEN_KEEPALIVE uint8_t* mplay_extras_vram_ptr() { return mplay_extras_vram; }
+EMSCRIPTEN_KEEPALIVE uint32_t mplay_extras_vram_size() { return sizeof(mplay_extras_vram); }
+EMSCRIPTEN_KEEPALIVE uint8_t* mplay_extras_cgram_ptr() { return mplay_extras_cgram; }
+EMSCRIPTEN_KEEPALIVE uint32_t mplay_extras_cgram_size() { return sizeof(mplay_extras_cgram); }
+
+EMSCRIPTEN_KEEPALIVE void mplay_extras_clear() {
+  memset(mplay_extras_obj, 0, sizeof(mplay_extras_obj));
+}
+
+}  // extern "C"
+
+// Second OBJ pass integration: see ppu-performance/object.cpp end-of-render
+// hook. (Patch lives in object.cpp; this file just provides the tables.)
